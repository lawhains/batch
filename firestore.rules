rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only read/write your own doc
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Deals
    match /deals/{dealId} {
      // Anyone can browse deals — no auth required to see what's available
      allow read: if true;

      // Deal creation is handled exclusively by the createDeal Cloud Function via Admin SDK.
      // Moving creation server-side lets the function enforce a per-user active deal limit
      // (Firestore rules have no aggregation support, so count checks must be server-side).
      // No client-side create rule is needed — the Admin SDK bypasses rules entirely.

      // Organiser can update their own deal's editable fields (e.g. title, pricePerPerson).
      // Four fields are off-limits from the client:
      //   status        — owned by Cloud Functions (onDealUpdated, expireDeals, lockDeal)
      //   currentBuyers — owned by Cloud Functions (joinDeal, leaveDeal)
      //   organizerId   — immutable after creation
      //   deadline      — immutable after creation (changing it would break the expiry sweep)
      // The Admin SDK used by Cloud Functions bypasses these rules entirely.
      allow update: if request.auth.uid == resource.data.organizerId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'currentBuyers', 'organizerId', 'deadline']);
    }

    // Commitments
    match /commitments/{commitmentId} {
      // Users can read their own commitments (e.g. to check if they've joined a deal).
      // resource is null when the doc doesn't exist (i.e. user hasn't joined yet) — allowing
      // that case is what lets the onSnapshot listener fire with snap.exists() === false
      // rather than throwing a permissions error before the user has ever joined.
      allow read: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);

      // No client-side create, update, or delete.
      // All commitment lifecycle operations are handled by Cloud Functions:
      //   joinDeal  — creates commitment doc + increments deal.currentBuyers
      //   leaveDeal — deletes commitment doc + decrements deal.currentBuyers
      // This is required for Stripe integration (PaymentIntent creation/cancellation)
      // and provides stronger security than client-side rules — the server validates
      // everything atomically in a single transaction.
    }
  }
}
