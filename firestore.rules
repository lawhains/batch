rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only read/write your own doc
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Deals
    match /deals/{dealId} {
      // Anyone can browse deals — no auth required to see what's available
      allow read: if true;

      // On creation, enforce that the incoming data is structurally valid.
      // This matters because client-side validation can be bypassed by anyone
      // hitting the Firestore REST API directly — the rules are the real enforcement.
      allow create: if request.auth != null
        // organizerId must match the person making the request — prevents impersonation
        && request.resource.data.organizerId == request.auth.uid
        // new deals must always start open with zero buyers
        && request.resource.data.status == 'open'
        && request.resource.data.currentBuyers == 0
        // basic field sanity checks
        && request.resource.data.pricePerPerson > 0
        && request.resource.data.minBuyers >= 2
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        // deadline must be a timestamp in the future — without this, a deal could be
        // created already expired (deadline in the past) or with no deadline at all,
        // which would make it immune to the expireDeals sweep
        && request.resource.data.deadline is timestamp
        && request.resource.data.deadline > request.time
        // maxBuyers is optional (null = unlimited), but when set it must be at least
        // minBuyers — otherwise the deal can never lock (it would hit capacity before
        // reaching the viability threshold)
        && (request.resource.data.maxBuyers == null
            || (request.resource.data.maxBuyers is int
                && request.resource.data.maxBuyers >= request.resource.data.minBuyers));

      // Organiser can update their own deal, but three fields are off-limits from the client:
      //   status       — owned by Cloud Functions (onDealUpdated, expireDeals)
      //   currentBuyers — owned by the joiner update rule below
      //   organizerId  — immutable after creation
      // The Admin SDK used by Cloud Functions bypasses these rules entirely, so
      // function-driven updates are unaffected by this restriction.
      allow update: if request.auth.uid == resource.data.organizerId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'currentBuyers', 'organizerId']);

      // Leaving a deal: mirror of joining — decrement currentBuyers by exactly 1 on an open deal.
      // The leave transaction also verifies the commitment exists, but rules can't check
      // cross-collection state, so this just enforces the field-level constraint.
      allow update: if request.auth != null
        && resource.data.status == 'open'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentBuyers'])
        && request.resource.data.currentBuyers == resource.data.currentBuyers - 1
        && resource.data.currentBuyers > 0;

      // Joining a deal: any authenticated user can increment currentBuyers by exactly 1,
      // but only on an open deal and only touching that one field.
      // The commitment doc (below) prevents double-joining; the transaction in the client
      // ensures both writes succeed or neither does.
      // The maxBuyers check ensures no one can join past the cap even via the REST API
      // (the client enforces this too, but rules are the real enforcement layer).
      allow update: if request.auth != null
        && resource.data.status == 'open'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentBuyers'])
        && request.resource.data.currentBuyers == resource.data.currentBuyers + 1
        && (resource.data.maxBuyers == null
            || resource.data.currentBuyers < resource.data.maxBuyers);
    }

    // Commitments
    match /commitments/{commitmentId} {
      // Users can read their own commitments (e.g. to check if they've joined a deal).
      // resource is null when the doc doesn't exist (i.e. user hasn't joined yet) — allowing
      // that case is what lets the onSnapshot listener fire with snap.exists() === false
      // rather than throwing a permissions error before the user has ever joined.
      allow read: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);

      // Creating a commitment: userId must match auth uid, and the doc ID must follow
      // the `{dealId}_{userId}` convention — this is what naturally prevents a user
      // from joining the same deal twice (the second create would fail with ALREADY_EXISTS)
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.dealId is string
        && commitmentId == request.resource.data.dealId + '_' + request.auth.uid
        && request.resource.data.status == 'pending';

      // Users can delete their own commitment to leave a deal, but only while
      // the deal is still open. Without the status check here, someone bypassing
      // the client (e.g. via the REST API) could delete their commitment on a
      // locked deal — leaving currentBuyers out of sync with actual commitment docs.
      // get() reads the parent deal doc to enforce this server-side.
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid
        && get(/databases/$(database)/documents/deals/$(resource.data.dealId)).data.status == 'open';

      // No client-side updates — changing commitment status (e.g. held → charged)
      // will be handled by Cloud Functions once Stripe is integrated
    }
  }
}
