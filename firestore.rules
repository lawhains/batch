rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only read/write your own doc
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Deals
    match /deals/{dealId} {
      // Anyone can browse deals — no auth required to see what's available
      allow read: if true;

      // On creation, enforce that the incoming data is structurally valid.
      // This matters because client-side validation can be bypassed by anyone
      // hitting the Firestore REST API directly — the rules are the real enforcement.
      allow create: if request.auth != null
        // organizerId must match the person making the request — prevents impersonation
        && request.resource.data.organizerId == request.auth.uid
        // new deals must always start open with zero buyers
        && request.resource.data.status == 'open'
        && request.resource.data.currentBuyers == 0
        // basic field sanity checks
        && request.resource.data.pricePerPerson > 0
        && request.resource.data.minBuyers >= 2
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        // deadline must be a timestamp in the future — without this, a deal could be
        // created already expired (deadline in the past) or with no deadline at all,
        // which would make it immune to the expireDeals sweep
        && request.resource.data.deadline is timestamp
        && request.resource.data.deadline > request.time
        // maxBuyers is optional (null = unlimited), but when set it must be at least
        // minBuyers — otherwise the deal can never lock (it would hit capacity before
        // reaching the viability threshold)
        && (request.resource.data.maxBuyers == null
            || (request.resource.data.maxBuyers is int
                && request.resource.data.maxBuyers >= request.resource.data.minBuyers));

      // Organiser can update their own deal's editable fields (e.g. title, pricePerPerson).
      // Four fields are off-limits from the client:
      //   status        — owned by Cloud Functions (onDealUpdated, expireDeals, lockDeal)
      //   currentBuyers — owned by Cloud Functions (joinDeal, leaveDeal)
      //   organizerId   — immutable after creation
      //   deadline      — immutable after creation (changing it would break the expiry sweep)
      // The Admin SDK used by Cloud Functions bypasses these rules entirely.
      allow update: if request.auth.uid == resource.data.organizerId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'currentBuyers', 'organizerId', 'deadline']);

      // Join and leave updates (currentBuyers increment/decrement) are handled
      // exclusively by the joinDeal and leaveDeal Cloud Functions via Admin SDK.
      // No client-side update rules are needed for these operations — this is more
      // secure than the previous approach because the server enforces all validation
      // (status, deadline, maxBuyers, double-join prevention) atomically.
    }

    // Commitments
    match /commitments/{commitmentId} {
      // Users can read their own commitments (e.g. to check if they've joined a deal).
      // resource is null when the doc doesn't exist (i.e. user hasn't joined yet) — allowing
      // that case is what lets the onSnapshot listener fire with snap.exists() === false
      // rather than throwing a permissions error before the user has ever joined.
      allow read: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);

      // No client-side create, update, or delete.
      // All commitment lifecycle operations are handled by Cloud Functions:
      //   joinDeal  — creates commitment doc + increments deal.currentBuyers
      //   leaveDeal — deletes commitment doc + decrements deal.currentBuyers
      // This is required for Stripe integration (PaymentIntent creation/cancellation)
      // and provides stronger security than client-side rules — the server validates
      // everything atomically in a single transaction.
    }
  }
}
