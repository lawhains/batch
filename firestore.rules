rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only read/write your own doc
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Deals
    match /deals/{dealId} {
      // Anyone can browse deals — no auth required to see what's available
      allow read: if true;

      // On creation, enforce that the incoming data is structurally valid.
      // This matters because client-side validation can be bypassed by anyone
      // hitting the Firestore REST API directly — the rules are the real enforcement.
      allow create: if request.auth != null
        // organizerId must match the person making the request — prevents impersonation
        && request.resource.data.organizerId == request.auth.uid
        // new deals must always start open with zero buyers
        && request.resource.data.status == 'open'
        && request.resource.data.currentBuyers == 0
        // basic field sanity checks
        && request.resource.data.pricePerPerson > 0
        && request.resource.data.minBuyers >= 2
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0;

      // Organiser can update their own deal — intentionally broad here because
      // deal locking and status changes will be driven by Cloud Functions later.
      // This will be tightened once that logic is in place.
      allow update: if request.auth.uid == resource.data.organizerId;

      // Joining a deal: any authenticated user can increment currentBuyers by exactly 1,
      // but only on an open deal and only touching that one field.
      // The commitment doc (below) prevents double-joining; the transaction in the client
      // ensures both writes succeed or neither does.
      allow update: if request.auth != null
        && resource.data.status == 'open'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentBuyers'])
        && request.resource.data.currentBuyers == resource.data.currentBuyers + 1;
    }

    // Commitments
    match /commitments/{commitmentId} {
      // Users can read their own commitments (e.g. to check if they've joined a deal).
      // resource is null when the doc doesn't exist (i.e. user hasn't joined yet) — allowing
      // that case is what lets the onSnapshot listener fire with snap.exists() === false
      // rather than throwing a permissions error before the user has ever joined.
      allow read: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);

      // Creating a commitment: userId must match auth uid, and the doc ID must follow
      // the `{dealId}_{userId}` convention — this is what naturally prevents a user
      // from joining the same deal twice (the second create would fail with ALREADY_EXISTS)
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.dealId is string
        && commitmentId == request.resource.data.dealId + '_' + request.auth.uid
        && request.resource.data.status == 'pending';

      // No client-side updates or deletes — releasing commitments will be handled
      // by Cloud Functions once Stripe is integrated
    }
  }
}
